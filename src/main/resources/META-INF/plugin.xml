<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>me.jinghong.git</id>
    <name>Git Blame</name>
    <vendor email="153335058@qq.com" url="https://gitee.com/youthdream">jinghong</vendor>
    <description><![CDATA[
        <p>在编辑器光标所在行末尾实时显示 Git Blame 信息（作者、时间、提交摘要），并在状态栏显示当前行 commit 的完整 hash。</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.jiangjinghong.git.blame.GitBlameService"/>
        <applicationService serviceImplementation="com.jiangjinghong.git.blame.settings.GitBlameSettings"/>
        <applicationConfigurable parentId="tools"
                                 instance="com.jiangjinghong.git.blame.settings.GitBlameConfigurable"
                                 id="com.jiangjinghong.git.blame.settings.GitBlameConfigurable"
                                 displayName="Git Blame"/>
        <editor.linePainter implementation="com.jiangjinghong.git.blame.line.GitLinePainter"/>
        <statusBarWidgetFactory id="GitBlameWidget"
                                implementation="com.jiangjinghong.git.blame.widget.GitBlameWidgetFactory"/>
    </extensions>
</idea-plugin>
